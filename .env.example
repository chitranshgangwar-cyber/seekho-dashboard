# ---- Google OAuth (from Google Cloud Console > Credentials > OAuth client ID) ----
AUTH_GOOGLE_ID=xxxxxxxx.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=xxxxxxxx
# random string: run `openssl rand -base64 32`
AUTH_SECRET=xxxxxxxx
# only needed for local dev; on Vercel it is auto-detected
# AUTH_URL=http://localhost:3000

# ---- Redash (so each build pulls fresh data) ----
REDASH_BASE_URL=https://analytics.seekho.in
REDASH_API_KEY=xxxxxxxx
Q_CREATIVE_ANALYTICS=00000
Q_CREATIVE_DASHBOARD2=00000
Q_RAW=00000
